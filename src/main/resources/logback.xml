<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- 运行时数据根目录: 优先使用系统属性 app.home, 未设置时兜底为 ~/.j_daily-alphaforge-analysis -->
    <!-- 防止 logback 在 AppInitializer 设置属性前提前加载导致生成 app.home_IS_UNDEFINED 目录 -->
    <property name="APP_HOME" value="${app.home:-${user.home}/.j_daily-stock-analysis}"/>

    <!-- 控制台输出 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 文件输出 (存储在 ~/.j_daily-alphaforge-analysis/logs/ 下) -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${APP_HOME}/logs/app.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${APP_HOME}/logs/app.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 数据源日志(降低级别避免刷屏) -->
    <logger name="com.stock.dataprovider" level="INFO"/>
    <!-- OkHttp日志 -->
    <logger name="okhttp3" level="WARN"/>
    <!-- Hibernate SQL -->
    <logger name="org.hibernate.SQL" level="WARN"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>
</configuration>
