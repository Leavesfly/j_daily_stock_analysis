# =============================================
# 股票智能分析系统 - Java版 环境配置
# 复制此文件为 .env 并填入实际配置
# =============================================

# ===== 基础配置 =====
# 待分析股票列表(逗号分隔)
STOCK_LIST=600519,002594,300750,hk00700,AAPL

# 目标市场: A/HK/US
MARKET=A

# 历史数据天数
HISTORY_DAYS=60

# 时区
TIMEZONE=Asia/Shanghai

# ===== LLM配置 =====
# LLM模型名称
LLM_MODEL=gpt-4o

# OpenAI兼容API地址
LLM_API_BASE=https://api.openai.com/v1

# API密钥
LLM_API_KEY=sk-xxx

# 备用LLM渠道(格式: model@base_url#api_key)
LLM_CHANNELS=

# Agent模式开关
AGENT_MODE=true

# ===== 数据源配置 =====
# 首选数据源: efinance/akshare/tushare/tencent/yfinance
DATA_PROVIDER=efinance

# Tushare Token(可选，配置后优先级提升)
TUSHARE_TOKEN=

# Finnhub API Key(美股)
FINNHUB_API_KEY=

# Alpha Vantage API Key
ALPHAVANTAGE_API_KEY=

# Longbridge(港股/美股)
LONGBRIDGE_APP_KEY=
LONGBRIDGE_APP_SECRET=
LONGBRIDGE_ACCESS_TOKEN=

# TickFlow
TICKFLOW_API_KEY=
TICKFLOW_BASE_URL=

# ===== 搜索/新闻配置 =====
SEARCH_PROVIDER=anspire
ANSPIRE_API_KEYS=
NEWS_MAX_RESULTS=5

# ===== 通知渠道配置 =====
# 启用的通知渠道(逗号分隔)
NOTIFICATION_CHANNELS=wecom

# 企业微信
WECOM_WEBHOOK_URL=

# 飞书
FEISHU_WEBHOOK_URL=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord
DISCORD_WEBHOOK_URL=

# Slack
SLACK_WEBHOOK_URL=

# 邮件
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
EMAIL_TO=

# PushPlus
PUSHPLUS_TOKEN=

# Pushover
PUSHOVER_USER_KEY=
PUSHOVER_APP_TOKEN=

# ntfy
NTFY_TOPIC=
NTFY_SERVER=https://ntfy.sh

# Gotify
GOTIFY_URL=
GOTIFY_TOKEN=

# Server酱3
SERVERCHAN3_KEY=

# 自定义Webhook
CUSTOM_WEBHOOK_URL=
CUSTOM_WEBHOOK_METHOD=POST

# AstrBot
ASTRBOT_WEBHOOK=

# ===== 认证配置 =====
AUTH_ENABLED=false
JWT_SECRET=your-jwt-secret-change-me
JWT_EXPIRE_HOURS=24

# ===== 定时调度 =====
# Cron表达式(工作日15:30)
SCHEDULE_CRON=0 30 15 * * MON-FRI

# ===== 存储 =====
STORAGE_DIR=./data
