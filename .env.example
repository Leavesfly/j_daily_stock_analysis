# =============================================
# 股票智能分析系统 - Java版 环境配置
# 复制此文件为 .env 并填入实际配置
#
# 标注说明:
#   [必填] - 不配置则应用核心功能不可用
#   [选填] - 有合理默认值，按需配置
# =============================================

# ===== 基础配置 =====
# [必填] 待分析股票列表(逗号分隔)，Web模式下可通过API传入，其他模式必须配置
STOCK_LIST=600519,002594,300750,hk00700,AAPL

# [选填] 目标市场: A/HK/US (默认: A)
MARKET=A

# [选填] 历史数据天数 (默认: 60)
HISTORY_DAYS=60

# [选填] 时区 (默认: Asia/Shanghai)
TIMEZONE=Asia/Shanghai

# ===== LLM配置 (AI分析核心) =====
# [必填] OpenAI兼容API地址 (默认: 阿里云百炼)
LLM_API=https://dashscope.aliyuncs.com/compatible-mode/v1

# [必填] API密钥 - 没有此配置AI分析功能完全不可用
LLM_API_KEY=sk-xxx

# [选填] LLM模型名称 (默认: qwen3.7-plus)
LLM_MODEL=qwen3.7-plus

# [选填] 备用LLM渠道(格式: provider://api_key@endpoint/model)
LLM_CHANNELS=

# [选填] Agent模式: quick/standard/full/specialist (默认: standard)
AGENT_MODE=standard

# ===== 数据源配置 =====
# [选填] 首选数据源: auto/efinance/akshare/tushare/tencent/yfinance (默认: auto)
DATA_PROVIDER=auto

# [选填] Tushare Token(配置后可使用Tushare数据源)
TUSHARE_TOKEN=

# [选填] Finnhub API Key(美股数据源)
FINNHUB_API_KEY=

# [选填] Alpha Vantage API Key
ALPHAVANTAGE_API_KEY=

# [选填] Longbridge(港股/美股数据源)
LONGBRIDGE_APP_KEY=
LONGBRIDGE_APP_SECRET=
LONGBRIDGE_ACCESS_TOKEN=

# [选填] TickFlow数据源
TICKFLOW_API_KEY=
TICKFLOW_BASE_URL=https://api.tickflow.io

# ===== 搜索/新闻配置 =====
# [选填] 搜索引擎: tavily/anspire (默认: tavily)
SEARCH_PROVIDER=tavily

# [选填] Tavily API Key (使用tavily搜索时需要)
TAVILY_API_KEY=

# [选填] Anspire API Key (使用anspire搜索时需要)
ANSPIRE_API_KEY=

# [选填] 新闻搜索最大结果数 (默认: 5)
NEWS_MAX_RESULTS=5

# ===== 通知渠道配置 =====
# [选填] 启用的通知渠道(逗号分隔)，不配置则不发送通知
NOTIFICATION_CHANNELS=

# [选填] 企业微信 Webhook
WECOM_WEBHOOK=

# [选填] 飞书 Webhook
FEISHU_WEBHOOK=

# [选填] Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# [选填] Discord Webhook
DISCORD_WEBHOOK=

# [选填] Slack Webhook
SLACK_WEBHOOK=

# [选填] 邮件通知
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=465
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_TO=

# [选填] PushPlus
PUSHPLUS_TOKEN=

# [选填] Pushover
PUSHOVER_USER_KEY=
PUSHOVER_APP_TOKEN=

# [选填] ntfy
NTFY_TOPIC=
NTFY_SERVER=https://ntfy.sh

# [选填] Gotify
GOTIFY_URL=
GOTIFY_TOKEN=

# [选填] Server酱3
SERVERCHAN3_KEY=

# [选填] 自定义Webhook
CUSTOM_WEBHOOK_URL=
CUSTOM_WEBHOOK_METHOD=POST

# [选填] AstrBot
ASTRBOT_WEBHOOK=

# ===== 认证配置 =====
# [选填] 是否启用认证 (默认: false)
AUTH_ENABLED=false

# [选填] JWT密钥 (启用认证时建议修改)
AUTH_SECRET=your-jwt-secret-change-me

# [选填] 认证密码
AUTH_PASSWORD=

# ===== 定时调度 =====
# [选填] Cron表达式 (默认: 工作日18:00)
SCHEDULE_CRON=0 0 18 * * MON-FRI

# ===== 服务配置 =====
# [选填] 服务端口 (默认: 8000)
SERVER_PORT=8000

# [选填] 服务绑定地址 (默认: 0.0.0.0)
SERVER_HOST=0.0.0.0
